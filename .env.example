# AI Provider Configuration
# Copy this file to .env and uncomment ONE provider section below.
# The editor will use mock AI responses if no provider is configured.

# ─── Provider Selection ─────────────────────────────────────
# VITE_AI_PROVIDER → 'openai' (default), 'anthropic', or 'ollama'

# ─── OpenAI (direct, no base URL needed) ────────────────────
# VITE_AI_MODEL=gpt-4o-mini
# VITE_AI_API_KEY=sk-...

# ─── Anthropic / Claude (native SDK) ───────────────────────
# VITE_AI_PROVIDER=anthropic
# VITE_AI_MODEL=claude-sonnet-4-20250514
# VITE_AI_API_KEY=sk-ant-...

# ─── Ollama (native SDK, no API key needed) ─────────────────
# VITE_AI_PROVIDER=ollama
# VITE_AI_MODEL=llama3
# VITE_AI_BASE_URL=http://localhost:11434

# ─── OpenAI-compatible (custom endpoint) ────────────────────
# For LiteLLM, vLLM, or any OpenAI-compatible API:
# VITE_AI_BASE_URL=http://localhost:4000
# VITE_AI_MODEL=glm-4.7
# VITE_AI_API_KEY=
