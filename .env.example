# AI Configuration — via LiteLLM Proxy
# All LLM API keys are configured in litellm-config.yaml, NOT here.
# Start the proxy with: just litellm

# LiteLLM proxy URL (default: http://localhost:4000)
VITE_AI_BASE_URL=http://localhost:4000

# Model name — must match a model_name in litellm-config.yaml
VITE_AI_MODEL=glm-4.7
